{
  "name": "vehicle-inspection-backend",
  "version": "1.0.0",
  "description": "Backend API for Vehicle Inspection App",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:bootstrap": "tsx src/scripts/bootstrap.ts",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:clean": "tsx src/scripts/clean.ts",
    "db:reset": "npm run db:clean && npm run db:seed",
    "seed": "npm run db:seed",
    "seed:prod": "tsx src/scripts/seedProd.ts"
  },
  "dependencies": {
    "@types/mssql": "^12.3.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^12.5.4",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "sharp": "^0.33.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "uuid": ">=11.1.1"
  }
}
