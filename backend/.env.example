# ── Servidor ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_64_char_random_string_in_production
JWT_EXPIRES_IN=12h

# ── SQL Server (Azure SQL) ───────────────────────────────────
# Si SQL Server corre en Windows y la app corre en Docker local:
#   MSSQL_HOST=host.docker.internal
MSSQL_HOST=tu-servidor.database.windows.net
MSSQL_PORT=1433
MSSQL_DATABASE=Operaciones
MSSQL_USER=vi_app
MSSQL_PASSWORD=TuPasswordSegura123!
MSSQL_ENCRYPT=true          # true para Azure SQL / false para SQL Server local sin SSL
MSSQL_TRUST_CERT=false      # true solo en entornos locales de desarrollo

# ── URL pública de la app ─────────────────────────────────────
PUBLIC_BASE_URL=http://localhost:3001

# ── Almacenamiento de fotos ──────────────────────────────────
# 'local' (default) → disco / volumen Docker `vi_uploads`.
# 'gcs'             → Google Cloud Storage (requiere implementar GcsPhotoStorage
#                     y `npm i @google-cloud/storage`; ver services/storage/).
STORAGE_DRIVER=local
# Solo para STORAGE_DRIVER=gcs:
# GCS_BUCKET=mi-bucket-de-fotos
# GCS_SIGNED_URL_TTL_MIN=15
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/al/service-account.json

# ── Origen permitido (CORS + cookies) ────────────────────────
# En producción debe coincidir EXACTAMENTE con el dominio del frontend
# (ej. https://flota.construmarket.com). El JWT viaja en una httpOnly
# cookie; si ALLOWED_ORIGIN no coincide con el origen real del navegador,
# el navegador bloqueará las peticiones CORS y la cookie no se enviará.
# En desarrollo no es necesario — el proxy de Vite hace que todo sea
# same-origin desde la perspectiva del navegador.
ALLOWED_ORIGIN=https://tu-dominio.construmarket.com

# ── Umbrales de negocio (se pueden sobreescribir desde Settings en BD) ───
DEFAULT_HIGH_MILEAGE_THRESHOLD=500
DEFAULT_NO_REVIEW_DAYS=3
